{
  "name": "contextselector",
  "version": "0.1.0",
  "description": "Launch a local web UI to explore codebases, curate context, and send selected files to Gemini from npx or a global npm install.",
  "author": "tayor",
  "bin": {
    "contextselector": "./bin/contextselector.js"
  },
  "keywords": [
    "cli",
    "context",
    "codebase",
    "developer-tools",
    "gemini",
    "nextjs"
  ],
  "homepage": "https://github.com/tayor/contextselector#readme",
  "bugs": {
    "url": "https://github.com/tayor/contextselector/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tayor/contextselector.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20.18.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "LICENSE",
    "bin",
    "app",
    "components",
    "lib",
    "utils",
    "types",
    "scripts",
    "assets",
    "proxy.ts",
    "next.config.mjs",
    "next-env.d.ts",
    "postcss.config.mjs",
    "tailwind.config.ts",
    "tsconfig.json",
    "components.json"
  ],
  "scripts": {
    "dev": "node scripts/run-next.mjs dev --webpack",
    "build": "next build --webpack",
    "start": "node scripts/run-next.mjs start --port 3001",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx,.mjs",
    "init-db": "node scripts/init-db.mjs",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fs-extra": "^11.3.4",
    "ignore": "^7.0.5",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "node-fetch": "^3.3.2",
    "postcss": "^8.5.10",
    "react": "^19.0.5",
    "react-dom": "^19.0.5",
    "sonner": "^2.0.7",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "@tailwindcss/postcss": "^4.2.2",
    "tailwindcss": "^4.2.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tiktoken": "^1.0.22",
    "typescript": "^6.0.3",
    "uuid": "^13.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4"
  },
  "packageManager": "npm@11.5.1"
}
